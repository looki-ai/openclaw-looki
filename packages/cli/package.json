{
  "name": "@looki-ai/openclaw-looki-cli",
  "version": "0.0.0",
  "description": "Lightweight installer for the OpenClaw Looki channel plugin",
  "license": "MIT",
  "author": "looki-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/looki-ai/openclaw-looki",
